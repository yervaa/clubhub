# Copy to `.env.local` for local dev. This file is safe to commit — use placeholders only.
# Real keys must never be committed (see `.gitignore`: `.env` / `.env.*` are ignored, not `.env.example`).

# ─── Supabase (required) ─────────────────────────────────────────────────────
# Never commit real keys. Use different projects for production vs local/staging.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-only: bypasses RLS. Used by admin client for audited server actions (tasks, notifications, audit).
# NEVER prefix with NEXT_PUBLIC_. Never import in client components.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── Rate limiting (required for production-style deploys) ─────────────────
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# ─── Demo seed ONLY (scripts/demo-seed/run.ts) ─────────────────────────────
# Do not set these on production user-facing projects unless you intend to wipe/seed demo data.

# Required to run demo seed when NODE_ENV=production or VERCEL_ENV=production
# ALLOW_DEMO_SEED=true

# Required when NEXT_PUBLIC_SUPABASE_URL host is NOT localhost / 127.0.0.1
# (e.g. hosted Supabase while NODE_ENV=development — prevents accidental remote wipe)
# DEMO_SEED_TARGET_OK=true

# ─── Pilot showcase ONLY (scripts/pilot-showcase/run.ts) ─────────────────────
# Wipes ALL auth users + all clubs. Use only on throwaway / pilot databases.
# Apply supabase/023_pilot_showcase_reset.sql before first run.
# ALLOW_PILOT_SHOWCASE=true
# PILOT_SHOWCASE_TARGET_OK=true
# PILOT_SHOWCASE_EMAIL=you@example.com
# PILOT_SHOWCASE_PASSWORD=choose-a-strong-password
